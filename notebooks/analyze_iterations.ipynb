   "source": [
    "def plot_metric(metric, title, ylabel):\n",
    "    plt.figure(figsize=(12, 6))\n",
    "    sns.lineplot(data=df, x='iterations', y=metric, hue='repairer', marker='o', errorbar=('ci', 95))\n",
    "    plt.title(title)\n",
    "    plt.xlabel('Co-Noise Iterations')\n",
    "    plt.ylabel(ylabel)\n",
    "    plt.grid(True)\n",
    "    plt.legend(bbox_to_anchor=(1.05, 1), loc='upper left')\n",
    "    plt.show()\n",
    "\n",
    "plot_metric('marginal_error_repaired', 'Marginal Error (Repaired) vs Iterations', 'Avg Marginal Error')\n",
    "plot_metric('deletion_ratio', 'Deletion Ratio vs Iterations', 'Ratio of Tuples Removed')\n",
    "plot_metric('ml_acc_rf_repaired', 'ML Accuracy (RF) vs Iterations', 'Accuracy')\n",
    "plot_metric('runtime_repairing', 'Repair Runtime vs Iterations', 'Seconds')\n",
    "plot_metric('violations_repaired', 'Remaining Violations vs Iterations', 'Count')"
   ]
  }
