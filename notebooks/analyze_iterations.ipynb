   "source": [
    "import pandas as pd\n",
    "import json\n",
    "import glob\n",
    "import os\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# 1. Load all results\n",
    "result_files = glob.glob(\"../results/**/*.json\", recursive=True)\n",
    "data_rows = []\n",
    "\n",
    "for f in result_files:\n",
    "    try:\n",
    "        with open(f, 'r') as jf:\n",
    "            res = json.load(jf)\n",
    "            \n",
    "            # Filter for our specific experiments\n",
    "            if \"adult5000_iters\" not in res.get('experiment_name', ''):\n",
    "                continue\n",
    "                \n",
    "            meta = res.get('metadata', {})\n",
    "            synth_params = meta.get('synthesizer_params', {})\n",
    "            repair_params = meta.get('repairer_params', {})\n",
    "            \n",
    "            # Determine Repairer label\n",
    "            repairer_type = meta.get('repairer', 'Unknown')\n",
    "            if repairer_type == 'ILPRepairer':\n",
    "                use_m = repair_params.get('use_marginals', True)\n",
    "                label = f\"ILP (Marginals={use_m})\"\n",
    "            else:\n",
    "                label = repairer_type\n",
    "            \n",
    "            row = {\n",
    "                'iterations': synth_params.get('num_of_iterations'),\n",
    "                'seed': synth_params.get('seed'),\n",
    "                'repairer': label,\n",
    "                'marginal_error_repaired': res.get('marginals_error', {}).get('repaired_avg'),\n",
    "                'marginal_error_synthetic': res.get('marginals_error', {}).get('synthetic_avg'),\n",
    "                'deletion_ratio': res.get('deletion_ratio', {}).get('ratio'),\n",
    'runtime_repairing': res.get('runtimes', {}).get('repairing'),
    'violations_repaired': res.get('violations', {}).get('repaired'),
    'ml_acc_rf_repaired': res.get('ml_accuracy', {}).get('repaired', {}).get('random_forest'),
    "                'ml_acc_lr_repaired': res.get('ml_accuracy', {}).get('repaired', {}).get('logistic_regression'),\n",
    "                'ml_acc_rf_private': res.get('ml_accuracy', {}).get('private_gold_standard', {}).get('random_forest'),\n",
    "                'tvd_repaired': res.get('tvd_2way', {}).get('repaired_avg')\n",
    "            }\n",
    "            data_rows.append(row)\n",
    "    except Exception as e:\n",
    "        print(f\"Error reading {f}: {e}\")\n",
    "\n",
    "df = pd.DataFrame(data_rows)\n",
    "df = df.sort_values(['iterations', 'repairer'])\n",
    "df.to_csv(\"experiment_results_summary.csv\", index=False)\n",
    "print(f\"Loaded {len(df)} results.\")\n",
    "df.head()"
   ]
  },
